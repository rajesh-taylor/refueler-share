  }
  .success-panel p { font-size: 14px; color: var(--fg-muted); margin-bottom: 28px; }

  .hidden { display: none !important; }

  @media (max-width: 680px) {
    .page { padding: 40px 16px 60px; }
    .tiers { grid-template-columns: 1fr; }
    .payment-section { padding: 20px 16px; }
    .manage-section { padding: 18px 16px; }
  }
  @media (prefers-reduced-motion: reduce) {
    *, html, body { transition: none !important; }
  }
</style>
</head>
<body>

{% set activePage = "upgrade" %}
{% include "nav.njk" %}

<!-- ── Main page ─────────────────────────────────────────────────── -->
<div class="page" id="mainPage">

