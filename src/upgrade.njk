    letter-spacing: 0.02em;
  }
  .btn-subscribe:hover:not(:disabled) { opacity: 0.88; }
  .btn-subscribe:disabled { opacity: 0.4; cursor: not-allowed; }

  /* ── Status messages ─────────────────────────────────────────── */
  .status-msg {
    font-size: 13px;
    padding: 10px 14px;
    border-radius: var(--radius);
    margin-bottom: 14px;
    display: none;
    font-family: var(--mono);
  }
  .status-msg.error {
    background: rgba(192,57,43,0.08);
    color: var(--danger);
    border: 1px solid rgba(192,57,43,0.2);
    display: block;
  }
  .status-msg.success {
    background: rgba(30,138,74,0.08);
    color: var(--success);
    border: 1px solid rgba(30,138,74,0.2);
    display: block;
