  .tier-card.free-card { cursor: default; }
  .tier-label {
    font-family: var(--display);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    margin-bottom: 14px;
  }
  .tier-label.gold { color: var(--gold); }
  .tier-name {
    font-family: var(--display);
    font-size: 17px;
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 12px;
  }
  .tier-price {
    display: flex;
