      </div>
    </div>
  </div>

</div>

<!-- Success panel -->
<div class="page">
  <div class="success-panel" id="successPanel">
    <div class="success-icon">✓</div>
    <h2>You're all set</h2>
    <p>Your subscription is active. Start sending large files now.</p>
    <a class="btn btn-primary" href="/">Go to upload →</a>
  </div>
</div>

{% include "footer.njk" %}

<script>
const WORKER_URL = 'https://refueler-share.rt-fc4.workers.dev';
const STRIPE_PK  = 'pk_test_r0s7pyX7tUlPjQuneYkblKjP00Sg2z63nJ';

const PRICE_IDS = {
  creative: {
    monthly: 'price_1TtnCEGlctwiB9U3tErRazp2',
    yearly:  'price_1TtnD0GlctwiB9U3UzFr27Zl',
  },
  max: {
    monthly: 'price_1TtnDVGlctwiB9U3BYGRnWl6',
    yearly:  'price_1TtnETGlctwiB9U3UJH3uaA',
  },
};

const PRICES_DISPLAY = {
  creative: { monthly: { price: '£12', period: '/ month' }, yearly: { price: '£120', period: '/ year' } },
  max:      { monthly: { price: '£24', period: '/ month' }, yearly: { price: '£240', period: '/ year' } },
};

let selectedTier   = 'creative';
let billingYearly  = false;
let stripe         = null;
let elements       = null;
let paymentElement = null;
let portalEmail    = null;

// ── URL param handling ──────────────────────────────────────────
const params = new URLSearchParams(location.search);
if (params.get('success') === '1') {
  document.getElementById('mainPage').style.display = 'none';
  document.getElementById('successPanel').classList.add('visible');
}

// ── Theme-aware Stripe remount ──────────────────────────────────
function remountStripeForTheme() {
  if (!elements) return;
  const email = document.getElementById('emailInput').value.trim();
  if (email && email.includes('@') && stripe) {
    elements = null;
    paymentElement = null;
    document.getElementById('payment-element').innerHTML = '';
    mountPaymentElement();
  }
}

// ── Billing toggle ──────────────────────────────────────────────
function toggleBilling() {
  billingYearly = !billingYearly;
  const toggle = document.getElementById('billingToggle');
  toggle.classList.toggle('on', billingYearly);
  document.getElementById('labelMonthly').classList.toggle('active', !billingYearly);
  document.getElementById('labelYearly').classList.toggle('active', billingYearly);
  updatePriceDisplay();
  updateSummary();
  resetPaymentElement();
}

function updatePriceDisplay() {
  ['creative', 'max'].forEach(tier => {
    const d = PRICES_DISPLAY[tier][billingYearly ? 'yearly' : 'monthly'];
    document.getElementById(`price-${tier}`).textContent = d.price;
    document.getElementById(`period-${tier}`).textContent = d.period;
  });
}

// ── Tier selection ──────────────────────────────────────────────
function selectTier(tier) {
  selectedTier = tier;
  document.querySelectorAll('.tier-card').forEach(c => c.classList.remove('selected'));
  document.getElementById(`card-${tier}`).classList.add('selected');
  updateSummary();
  resetPaymentElement();
}

function updateSummary() {
  const names   = { creative: 'Creative Premium', max: 'Production Max' };
  const billing = billingYearly ? 'yearly' : 'monthly';
  const d       = PRICES_DISPLAY[selectedTier][billing];
  document.getElementById('paymentSummary').textContent =
    `${names[selectedTier]} — ${d.price}${d.period.replace('/', '').trim()}`;
}

function resetPaymentElement() {
  elements = null;
  paymentElement = null;
  document.getElementById('payment-element').innerHTML = '';
  const email = document.getElementById('emailInput').value.trim();
  if (email && email.includes('@') && stripe) mountPaymentElement();
}

// ── Stripe ──────────────────────────────────────────────────────
async function initStripe() {
  stripe = Stripe(STRIPE_PK);
  await mountPaymentElement();
}

async function mountPaymentElement() {
  const priceId = PRICE_IDS[selectedTier][billingYearly ? 'yearly' : 'monthly'];
  const email   = document.getElementById('emailInput').value.trim();
  if (!email) return;

  showStatus('');
  const btn = document.getElementById('submitBtn');
  btn.disabled = true;
  btn.textContent = 'Loading…';

  try {
    const res = await fetch(`${WORKER_URL}/subscription/checkout`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ price_id: priceId, email }),
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Checkout failed');

    if (elements) elements.unmount();
    elements = stripe.elements({
      clientSecret: data.client_secret,
      appearance: stripeAppearance(),
    });
    paymentElement = elements.create('payment');
    paymentElement.mount('#payment-element');
    paymentElement.on('ready', () => {
      btn.disabled = false;
      btn.textContent = 'Subscribe now';
    });
  } catch (e) {
    showStatus(e.message, 'error');
    btn.disabled = false;
    btn.textContent = 'Subscribe now';
  }
}

async function handleSubmit() {
  const email = document.getElementById('emailInput').value.trim();
  if (!email || !email.includes('@')) {
    showStatus('Please enter a valid email address.', 'error');
    return;
  }
  if (!elements) {
    await mountPaymentElement();
    return;
  }
  const btn = document.getElementById('submitBtn');
  btn.disabled = true;
  btn.textContent = 'Processing…';
  showStatus('');

  const { error } = await stripe.confirmPayment({
    elements,
    confirmParams: {
      return_url:     `${location.origin}/upgrade.html?success=1`,
      receipt_email:  email,
    },
    redirect: 'if_required',
  });

  if (error) {
    showStatus(error.message, 'error');
    btn.disabled = false;
    btn.textContent = 'Subscribe now';
  } else {
    document.getElementById('mainPage').style.display = 'none';
    const successPanel = document.getElementById('successPanel');
    successPanel.classList.add('visible');
    portalEmail = email;
    const manageLink = document.createElement('p');
    manageLink.style.cssText = 'margin-top:16px;font-size:13px;';
    manageLink.innerHTML = `<a href="#" onclick="openPortal();return false;" style="color:var(--gold);">Manage subscription →</a>`;
    successPanel.appendChild(manageLink);
  }
}

// Mount Stripe on email blur
document.getElementById('emailInput').addEventListener('blur', () => {
  const email = document.getElementById('emailInput').value.trim();
  if (email && email.includes('@') && !elements) initStripe();
});

// ── Tab switching ───────────────────────────────────────────────
function switchTab(tab) {
  const isCard = tab === 'card';
  document.querySelectorAll('.pay-tab').forEach((t, i) => t.classList.toggle('active', isCard ? i === 0 : i === 1));
  document.querySelectorAll('.tab-pane').forEach((p, i) => p.classList.toggle('active', isCard ? i === 0 : i === 1));
}

// ── Status messages ─────────────────────────────────────────────
function showStatus(msg, type = '') {
  const el = document.getElementById('statusMsg');
  el.textContent = msg;
  el.className = `status-msg${type ? ' ' + type : ''}`;
}
function showLookupStatus(msg, type = '') {
  const el = document.getElementById('lookupStatus');
  el.textContent = msg;
  el.className = `status-msg${type ? ' ' + type : ''}`;
}

// ── Portal ──────────────────────────────────────────────────────
async function openPortal() {
  if (!portalEmail) return;
  const btn = document.getElementById('portalBtn');
  btn.disabled = true;
  btn.textContent = 'Opening…';
  try {
    const res = await fetch(`${WORKER_URL}/subscription/portal`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: portalEmail }),
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Portal unavailable');
    window.location.href = data.url;
  } catch (e) {
    btn.disabled = false;
    btn.textContent = 'Manage subscription →';
    showLookupStatus(e.message, 'error');
  }
}

async function lookupAndOpenPortal() {
  const email = document.getElementById('lookupEmail').value.trim();
  if (!email || !email.includes('@')) {
    showLookupStatus('Please enter a valid email address.', 'error');
    return;
  }
  const btn = document.getElementById('lookupBtn');
  btn.disabled = true;
  btn.textContent = '…';
  showLookupStatus('');
  try {
    const res = await fetch(`${WORKER_URL}/subscription/portal`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email }),
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'No active subscription found for this email.');
    window.location.href = data.url;
  } catch (e) {
    btn.disabled = false;
    btn.textContent = 'Go →';
    showLookupStatus(e.message, 'error');
  }
}

function showManageSection(email, tierName) {
  portalEmail = email;
  document.getElementById('managePlanName').textContent = tierName;
  document.getElementById('manageSection').classList.add('visible');
  document.getElementById('manageLookup').style.display = 'none';
}

// ── Stripe appearance — theme-aware ────────────────────────────
function stripeAppearance() {
  const isDark = document.documentElement.classList.contains('carbon-mode');
  return {
    theme: isDark ? 'night' : 'stripe',
    variables: {
      colorPrimary:     '#C8A96E',
      colorBackground:  isDark ? '#252525' : '#FFFFFF',
      colorText:        isDark ? '#F5F0E8' : '#1A1A1A',
      colorDanger:      isDark ? '#E05555' : '#C0392B',
      fontFamily:       'DM Sans, sans-serif',
      borderRadius:     '6px',
    },
  };
}
</script>
</body>
</html>
