  .payment-note { text-align: center; font-size: 12px; color: var(--fg-subtle); margin-top: 14px; line-height: 1.6; }
  .payment-note a { color: var(--gold-dim); text-decoration: none; }
  .payment-note a:hover { color: var(--gold); }

  /* ── Success panel ───────────────────────────────────────────── */
  .success-panel { text-align: center; padding: 80px 24px; display: none; }
  .success-panel.visible { display: block; }
  .success-icon { font-size: 36px; margin-bottom: 20px; opacity: 0.7; }
