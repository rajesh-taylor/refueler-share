    <!-- Creative Premium -->
    <div class="tier-card selected" id="card-creative" onclick="selectTier('creative')">
      <div class="tier-label gold">Creative</div>
      <div class="tier-name">Creative Premium</div>
      <div class="tier-price">
        <span class="tier-price-main" id="price-creative">£12</span>
        <span class="tier-price-period" id="period-creative">/ month</span>
      </div>
      <div class="tier-yearly" id="yearly-creative">or £120/yr — <strong>2 months free</strong></div>
      <ul class="tier-features">
        <li>100 GB per transfer</li>
        <li>1 / 7 / 30 day expiry</li>
        <li>End-to-end encrypted</li>
