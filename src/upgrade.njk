    </div>

    <!-- Production Max -->
    <div class="tier-card" id="card-max" onclick="selectTier('max')">
      <div class="tier-label gold">Professional</div>
      <div class="tier-name">Production Max</div>
      <div class="tier-price">
        <span class="tier-price-main" id="price-max">£24</span>
