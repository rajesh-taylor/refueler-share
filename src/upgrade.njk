  .lightning-placeholder { text-align: center; padding: 40px 20px; color: var(--fg-subtle); }
  .lightning-placeholder .lp-icon { font-size: 28px; margin-bottom: 12px; opacity: 0.5; }
  .lightning-placeholder p { font-size: 13px; line-height: 1.6; }

