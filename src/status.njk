---
title: "System Status — refueler share"
description: "Real-time operational status and cryptographic integrity layer for share.refueler.io."
permalink: /status.html
activePage: ""
---
<!DOCTYPE html>
<html lang="en">
<head>
{% include "head.njk" %}
{% include "shared-styles.njk" %}
<style>
  /* ── Status page layout ────────────────────────────────────────────── */
  .shell {
    max-width: 720px;
    margin: 0 auto;
    padding: 56px clamp(1.25rem, 4vw, 3rem) 80px;
  }

  .status-hero {
    margin-bottom: 48px;
  }
  .status-back-link {
    display: inline-block;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--fg-muted);
    text-decoration: none;
    margin-bottom: 20px;
    transition: color 0.15s;
  }
  .status-back-link:hover { color: var(--fg); }
  .status-hero-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    margin-bottom: 12px;
  }
  .status-hero-headline {
    font-family: var(--display);
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--fg);
    margin-bottom: 8px;
  }
  .status-hero-updated {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--fg-subtle);
  }

  /* ── State indicator ────────────────────────────────────────────────── */
  .state-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 20px;
    border-radius: var(--radius);
    border: 1px solid transparent;
    margin-bottom: 32px;
    transition: background 0.25s, border-color 0.25s;
  }
  .state-card[data-state="operational"] {
    background: color-mix(in srgb, #27AE60 8%, var(--bg));
    border-color: color-mix(in srgb, #27AE60 22%, transparent);
  }
  .state-card[data-state="degraded"] {
    background: color-mix(in srgb, #C0392B 8%, var(--bg));
    border-color: color-mix(in srgb, #C0392B 22%, transparent);
  }
  .state-card[data-state="maintenance"] {
    background: color-mix(in srgb, #C8A951 8%, var(--bg));
    border-color: color-mix(in srgb, #C8A951 22%, transparent);
  }
  .state-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  [data-state="operational"] .state-dot { background: #27AE60; }
  [data-state="degraded"]    .state-dot { background: #C0392B; animation: pulse-red 1.6s ease infinite; }
  [data-state="maintenance"] .state-dot { background: #C8A951; animation: pulse-amber 1.6s ease infinite; }

  @keyframes pulse-red {
    0%, 100% { box-shadow: 0 0 0 0 rgba(192,57,43,0.5); }
    50%       { box-shadow: 0 0 0 5px rgba(192,57,43,0); }
  }
  @keyframes pulse-amber {
    0%, 100% { box-shadow: 0 0 0 0 rgba(200,169,81,0.5); }
    50%       { box-shadow: 0 0 0 5px rgba(200,169,81,0); }
  }

  .state-label {
    font-family: var(--display);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--fg);
  }
  .state-message {
    font-size: 13px;
    color: var(--fg-muted);
    margin-top: 2px;
  }

  /* ── Section headers ───────────────────────────────────────────────── */
  .section-header {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }
  .section-title {
    font-family: var(--display);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }

  /* ── Maintenance window ─────────────────────────────────────────────── */
  .maintenance-block {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    padding: 16px 18px;
    margin-bottom: 24px;
  }
  .maintenance-block-title {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 500;
    color: var(--fg);
    margin-bottom: 4px;
  }
  .maintenance-block-meta {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--fg-muted);
    line-height: 1.7;
  }

  /* ── Incidents ──────────────────────────────────────────────────────── */
  .incident-list { display: flex; flex-direction: column; gap: 12px; margin-bottom: 32px; }
  .incident-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    padding: 16px 18px;
  }
  .incident-card-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }
  .incident-severity {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 2px 7px;
    border-radius: 3px;
  }
  .severity-minor    { background: color-mix(in srgb, #C8A951 15%, var(--bg)); color: #C8A951; }
  .severity-major    { background: color-mix(in srgb, #C0392B 15%, var(--bg)); color: #C0392B; }
  .severity-critical { background: color-mix(in srgb, #C0392B 25%, var(--bg)); color: #C0392B; font-weight: 600; }

  .incident-title {
    font-family: var(--display);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--fg);
  }
  .incident-resolved-badge {
    margin-left: auto;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #27AE60;
  }
  .incident-times {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--fg-subtle);
    margin-bottom: 8px;
  }
  .incident-updates { display: flex; flex-direction: column; gap: 6px; }
  .incident-update {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 8px;
    font-size: 12px;
  }
  .incident-update-time {
    font-family: var(--mono);
    color: var(--fg-subtle);
    font-size: 11px;
  }
  .incident-update-body { color: var(--fg-muted); line-height: 1.5; }

  .no-incidents {
    font-size: 13px;
    color: var(--fg-subtle);
    font-family: var(--mono);
    padding: 12px 0;
  }

  /* ── Cryptographic integrity section ────────────────────────────────── */
  .integrity-section { margin-top: 48px; }

  .integrity-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 16px;
  }
  @media (max-width: 560px) { .integrity-grid { grid-template-columns: 1fr; } }

  .integrity-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    padding: 16px 18px;
  }
  .integrity-card-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    margin-bottom: 8px;
  }
  .integrity-card-value {
    font-family: var(--display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 8px;
  }
  .integrity-card-note {
    font-size: 13px;
    color: var(--fg-muted);
    line-height: 1.6;
  }

  /* Known gap — amber treatment */
  .integrity-card.gap {
    border-color: color-mix(in srgb, #C8A951 30%, transparent);
    background: color-mix(in srgb, #C8A951 5%, var(--bg));
  }
  .integrity-card.gap .integrity-card-value { color: #C8A951; }

  /* ── Loading / error states ─────────────────────────────────────────── */
  .loading-state {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--fg-subtle);
    padding: 20px 0;
    text-align: center;
  }
  .fetch-error {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--fg-muted);
    padding: 12px 0;
  }
</style>
</head>

<body>
{% include "nav.njk" %}

<main class="shell">

  <!-- ── Hero ──────────────────────────────────────────────────────────── -->
  <div class="status-hero">
    <a href="/index.html" class="status-back-link">← Back to Refueler Share</a>
    <h1 class="status-hero-headline">Service Status</h1>
    <p class="status-hero-updated subtle" id="hero-updated">Checking…</p>
  </div>

  <!-- ── Ops layer ─────────────────────────────────────────────────────── -->
  <section id="ops-section">

    <!-- State indicator — populated by JS -->
    <div class="state-card" id="state-card" data-state="operational">
      <span class="state-dot"></span>
      <div>
        <div class="state-label" id="state-label">Loading…</div>
        <div class="state-message" id="state-message"></div>
      </div>
    </div>

    <!-- Maintenance window (hidden if none) -->
    <div id="maintenance-block" class="hidden">
      <div class="section-header">
        <span class="section-title">Scheduled maintenance</span>
      </div>
      <div class="maintenance-block">
        <div class="maintenance-block-title" id="mw-title"></div>
        <div class="maintenance-block-meta" id="mw-meta"></div>
      </div>
    </div>

    <!-- Incidents -->
    <div class="section-header">
      <span class="section-title">Incidents</span>
    </div>
    <div class="incident-list" id="incident-list">
      <p class="loading-state">Fetching status…</p>
    </div>

  </section>

  <!-- ── How it works ─────────────────────────────────────────────────── -->
  <section class="integrity-section">

    <div class="section-header">
      <span class="section-title">How it works</span>
    </div>

    <div class="integrity-grid">

      <div class="integrity-card">
        <div class="integrity-card-label">Technical: AES-256-GCM · RFC 3986 fragment</div>
        <div class="integrity-card-value">✓ Encrypted in your browser</div>
        <div class="integrity-card-note">
          Your file is encrypted before it leaves your device. The key lives only in the
          share link — we never see it, and neither does anyone who handles the transfer in transit.
        </div>
      </div>

      <div class="integrity-card">
        <div class="integrity-card-label">Technical: Cashu NUT-00 blind signatures · NUT-07 double-spend ledger</div>
        <div class="integrity-card-value">✓ Transfers can't be linked to you</div>
        <div class="integrity-card-note">
          No account. No email. Uploads are authorised by an anonymous credential —
          the server grants access without learning who you are.
        </div>
      </div>

      <div class="integrity-card">
        <div class="integrity-card-label">Technical: BLAKE3 WASM · server-side chunk verification</div>
        <div class="integrity-card-value">✓ Files arrive intact</div>
        <div class="integrity-card-note">
          Each chunk is hashed before upload and verified by the server on receipt.
          Any corruption or tampering in transit is caught and rejected automatically.
        </div>
      </div>

      <div class="integrity-card">
        <div class="integrity-card-label">Technical: SHA-256 passphrase hash · NUT-11 Mode 1</div>
        <div class="integrity-card-value">✓ Optional passphrase lock</div>
        <div class="integrity-card-note">
          You can protect a share link with a passphrase. The passphrase never travels
          the wire — only its hash is stored, and the server checks it before issuing a download token.
        </div>
      </div>

      <div class="integrity-card">
        <div class="integrity-card-label">Technical: Cloudflare R2 lifecycle rules · 92-day hard cap</div>
        <div class="integrity-card-value">✓ Files delete themselves</div>
        <div class="integrity-card-note">
          Every transfer has an expiry. When it passes, the file is deleted automatically
          by Cloudflare's storage layer — no manual intervention, no exceptions, no lingering copies.
        </div>
      </div>

      <div class="integrity-card">
        <div class="integrity-card-label">Technical: rate limiting · UUID-bound credentials · Turnstile</div>
        <div class="integrity-card-value">✓ Abuse prevention</div>
        <div class="integrity-card-note">
          Each upload credential is cryptographically bound to a single transfer.
          Rate limits and bot detection prevent the service being used as a relay for bulk abuse.
        </div>
      </div>

    </div>

  </section>

</main>

{% include "footer.njk" %}

<script>
(function () {
  const WORKER_URL = 'https://refueler-share.rt-fc4.workers.dev';

  // ── DOM refs ──────────────────────────────────────────────────────────
  const stateCard       = document.getElementById('state-card');
  const stateLabel      = document.getElementById('state-label');
  const stateMessage    = document.getElementById('state-message');
  const heroUpdated     = document.getElementById('hero-updated');
  const maintenanceBlock = document.getElementById('maintenance-block');
  const mwTitle         = document.getElementById('mw-title');
  const mwMeta          = document.getElementById('mw-meta');
  const incidentList    = document.getElementById('incident-list');

  // ── Formatters ────────────────────────────────────────────────────────
  function fmtDatetime(unix) {
    return new Date(unix * 1000).toLocaleString('en-GB', {
      weekday: 'short', day: 'numeric', month: 'short', year: 'numeric',
      hour: '2-digit', minute: '2-digit', timeZoneName: 'short',
    });
  }

  function fmtRelative(unix) {
    const diff = Math.floor(Date.now() / 1000) - unix;
    if (diff < 60)   return 'just now';
    if (diff < 3600) return `${Math.floor(diff / 60)}m ago`;
    if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
    return `${Math.floor(diff / 86400)}d ago`;
  }

  // ── State card ────────────────────────────────────────────────────────
  function renderState(status) {
    const state = status.state ?? 'operational';
    stateCard.dataset.state = state;

    const labels = {
      operational: 'Refueler Share is running normally',
      degraded:    'Something is wrong — we\'re looking into it',
      maintenance: 'Maintenance in progress — back shortly',
    };
    stateLabel.textContent = labels[state] ?? state;

    if (status.message && state !== 'operational') {
      stateMessage.textContent = status.message;
    } else {
      stateMessage.textContent = '';
    }
  }

  // ── Maintenance window ────────────────────────────────────────────────
  function renderMaintenance(mw) {
    if (!mw) {
      maintenanceBlock.classList.add('hidden');
      return;
    }
    maintenanceBlock.classList.remove('hidden');

    mwTitle.textContent = mw.description ?? 'Scheduled maintenance';

    const lines = [];
    if (mw.scheduled_at) lines.push(`Scheduled: ${fmtDatetime(mw.scheduled_at)}`);
    if (mw.duration_minutes) lines.push(`Duration: ${mw.duration_minutes} min`);
    mwMeta.textContent = lines.join('\n');
  }

  // ── Incidents ─────────────────────────────────────────────────────────
  function renderIncidents(incidents) {
    if (!incidents || incidents.length === 0) {
      incidentList.innerHTML = '<p class="no-incidents">No incidents in the current period.</p>';
      return;
    }

    // Most recent first
    const sorted = [...incidents].sort((a, b) => (b.started_at ?? 0) - (a.started_at ?? 0));

    incidentList.innerHTML = sorted.map(inc => {
      const severityClass = `severity-${inc.severity ?? 'minor'}`;
      const resolvedBadge = inc.resolved_at
        ? `<span class="incident-resolved-badge">Resolved</span>`
        : '';

      const times = [];
      if (inc.started_at)  times.push(`Started: ${fmtDatetime(inc.started_at)} (${fmtRelative(inc.started_at)})`);
      if (inc.resolved_at) times.push(`Resolved: ${fmtDatetime(inc.resolved_at)}`);

      const updates = inc.updates && inc.updates.length
        ? inc.updates.map(u => `
            <div class="incident-update">
              <span class="incident-update-time">${fmtDatetime(u.at)}</span>
              <span class="incident-update-body">${escHtml(u.body)}</span>
            </div>`).join('')
        : '';

      return `
        <div class="incident-card">
          <div class="incident-card-head">
            <span class="incident-severity ${severityClass}">${escHtml(inc.severity ?? 'minor')}</span>
            <span class="incident-title">${escHtml(inc.title ?? 'Incident')}</span>
            ${resolvedBadge}
          </div>
          ${times.length ? `<div class="incident-times">${times.join(' · ')}</div>` : ''}
          ${updates ? `<div class="incident-updates">${updates}</div>` : ''}
        </div>`;
    }).join('');
  }

  // ── Hero timestamp ────────────────────────────────────────────────────
  function renderUpdated(updated_at) {
    if (!updated_at) { heroUpdated.textContent = ''; return; }
    heroUpdated.textContent = `Last updated: ${fmtDatetime(updated_at)}`;
  }

  // ── Escape helper ─────────────────────────────────────────────────────
  function escHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  // ── Fetch and render ──────────────────────────────────────────────────
  async function loadStatus() {
    let status;
    try {
      const res = await fetch(`${WORKER_URL}/status`, { cache: 'no-store' });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      status = await res.json();
    } catch {
      stateCard.dataset.state  = 'degraded';
      stateLabel.textContent   = 'Status check failed';
      stateMessage.textContent = 'We couldn\'t reach the status endpoint. The service may be temporarily unavailable, or your network may be blocking the request.';
      incidentList.innerHTML   = '<p class="fetch-error">Incident data is unavailable right now. Try refreshing in a moment.</p>';
      heroUpdated.textContent  = '';
      return;
    }

    renderState(status);
    renderMaintenance(status.maintenance ?? null);
    renderIncidents(status.incidents ?? []);
    renderUpdated(status.updated_at ?? null);
  }

  loadStatus();

  // Refresh every 60 s — status page stays accurate without a reload
  setInterval(loadStatus, 60_000);
})();
</script>

</body>
</html>
